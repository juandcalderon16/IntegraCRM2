# Backend (Spring Boot)
DATABASE_URL=jdbc:postgresql://localhost:5432/crm
DATABASE_USER=crm
DATABASE_PASSWORD=crmsecret
JWT_SECRET=change-me-long-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000
CORS_ORIGINS=http://localhost:5173

# Supabase (opcional): tras crear proyecto, usa la URL JWKS del tenant
# SUPABASE_JWK_SET_URI=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1

